/**
 * MTOS Auth Middleware
 *
 * Fixes: HIGH-01 — Impersonation JWT flag (isImpersonation: true) was never
 *                  checked. All actions during impersonation were audit-logged
 *                  as the victim COMPANY_ADMIN, making forensics impossible.
 *
 * Design contract:
 *  - protect() is the JWT-verification and user-hydration middleware.
 *  - When isImpersonation === true, req.impersonatedBy is set to the
 *    SUPER_ADMIN's user record, and req.user is the impersonated account.
 *  - All downstream middleware and controllers use req.user for authorization.
 *  - All audit log calls must pass req.auditActors (see below) so both actors
 *    are recorded on every action taken during an impersonation session.
 *  - impersonateOnly() middleware guards routes that REQUIRE active impersonation.
 *  - noImpersonation() middleware guards routes that must NOT be callable
 *    during an impersonation session (e.g. change password, billing actions).
 */

'use strict';

const jwt = require('jsonwebtoken');

// ─── protect ─────────────────────────────────────────────────────────────────

/**
 * Verifies JWT, hydrates req.user, and (HIGH-01 fix) detects impersonation.
 *
 * Sets on req:
 *   req.user            – the operating user account (may be impersonated)
 *   req.impersonatedBy  – the SUPER_ADMIN who initiated impersonation, or null
 *   req.isImpersonation – boolean convenience flag
 *   req.auditActors     – { actorId, actorRole, impersonatedById? }
 *                         Pass this to every auditService.log() call.
 */
async function protect(getUserById) {
  // Returns the actual Express middleware (factory pattern keeps getUserById injected)
  return async function protectMiddleware(req, res, next) {
    const authHeader = req.headers.authorization;
    if (!authHeader || !authHeader.startsWith('Bearer ')) {
      return res.status(401).json({ error: 'No token provided' });
    }

    const token  = authHeader.slice(7);
    let   decoded;

    try {
      decoded = jwt.verify(token, process.env.JWT_SECRET);
    } catch (err) {
      return res.status(401).json({
        error: err.name === 'TokenExpiredError' ? 'Token expired' : 'Invalid token',
      });
    }

    // Hydrate the operating user
    const user = await getUserById(decoded.userId);
    if (!user || !user.isActive) {
      return res.status(401).json({ error: 'User not found or inactive' });
    }

    req.user = user;

    // ── HIGH-01 FIX: Detect and record impersonation ──────────────────────
    if (decoded.isImpersonation === true) {
      if (!decoded.impersonatedBy) {
        // Malformed impersonation token — reject
        return res.status(401).json({ error: 'Malformed impersonation token' });
      }

      const superAdmin = await getUserById(decoded.impersonatedBy);
      if (!superAdmin || superAdmin.role !== 'SUPER_ADMIN') {
        return res.status(401).json({ error: 'Invalid impersonation origin' });
      }

      req.impersonatedBy  = superAdmin;
      req.isImpersonation = true;

      // auditActors: downstream code passes this object to every audit log call.
      // The audit record will show BOTH the super admin AND the victim account,
      // making it impossible to forge "clean" audit logs during impersonation.
      req.auditActors = {
        actorId:          superAdmin.id,       // true actor for audit purposes
        actorRole:        superAdmin.role,
        impersonatingId:  user.id,             // the account being impersonated
        impersonatingRole: user.role,
        isImpersonation:  true,
      };
    } else {
      req.impersonatedBy  = null;
      req.isImpersonation = false;
      req.auditActors = {
        actorId:         user.id,
        actorRole:       user.role,
        isImpersonation: false,
      };
    }

    next();
  };
}

// ─── Role guards ──────────────────────────────────────────────────────────────

/**
 * Restricts a route to specific roles.
 * @param {...string} roles
 */
function requireRole(...roles) {
  return (req, res, next) => {
    if (!req.user) {
      return res.status(401).json({ error: 'Unauthenticated' });
    }
    if (!roles.includes(req.user.role)) {
      return res.status(403).json({
        error: `Access denied. Required roles: ${roles.join(', ')}`,
      });
    }
    next();
  };
}

/**
 * Blocks routes that MUST NOT be accessible during impersonation.
 * Protects billing, password-change, and sensitive preference mutations.
 *
 * HIGH-01 fix: Without this guard, a SUPER_ADMIN impersonating a COMPANY_ADMIN
 * could change billing plans or billing details on behalf of the victim tenant
 * with no audit trail pointing back to the super admin.
 */
function noImpersonation(req, res, next) {
  if (req.isImpersonation) {
    return res.status(403).json({
      error: 'This action cannot be performed during an impersonation session. ' +
             'Exit impersonation and perform this action as yourself.',
    });
  }
  next();
}

/**
 * Requires active impersonation context (for impersonation-management routes).
 */
function requireImpersonation(req, res, next) {
  if (!req.isImpersonation) {
    return res.status(403).json({ error: 'Active impersonation session required' });
  }
  next();
}

// ─── Tenant isolation guard ───────────────────────────────────────────────────

/**
 * Injects tenantId from req.user into req.tenantId.
 * All repository functions receive this value; never read tenantId from
 * request body/params (those are user-controlled).
 */
function injectTenantId(req, res, next) {
  if (!req.user || !req.user.tenantId) {
    return res.status(400).json({ error: 'User has no associated tenant' });
  }
  req.tenantId = req.user.tenantId;
  next();
}

module.exports = {
  protect,
  requireRole,
  noImpersonation,
  requireImpersonation,
  injectTenantId,
};
