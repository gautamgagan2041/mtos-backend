# ─── MTOS v2 Environment Variables ───────────────────────────
# Copy this to .env and fill in your values

# ── App ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://mtos_user:mtos_pass@localhost:5432/mtos_db?schema=public"

# ── Auth ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=replace_with_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=7d

# ── File Storage ──────────────────────────────────────────────
# LOCAL: files saved to ./uploads/
# S3:    files saved to AWS S3 (set per-tenant in the DB)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# AWS S3 (required only if any tenant uses S3 storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=

# ── Backup ────────────────────────────────────────────────────
BACKUP_DIR=/var/backups/mtos
RETENTION_DAYS=7
BACKUP_S3_BUCKET=
BACKUP_SLACK_WEBHOOK=

# ── Email (optional — for compliance alerts) ──────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com
